# PayOS credentials (from https://my.payos.vn → Kênh thanh toán → API)
PAYOS_CLIENT_ID=your_client_id_here
PAYOS_API_KEY=your_api_key_here
PAYOS_CHECKSUM_KEY=your_checksum_key_here

# Shopify custom app credentials
# Store domain (e.g. mocbydylan.myshopify.com — no https://)
SHOPIFY_STORE_DOMAIN=mocbydylan.myshopify.com
# Admin API access token from Settings → Apps → Develop apps → API credentials
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Vercel KV (Upstash Redis) — from Vercel project → Storage → KV
KV_REST_API_URL=https://xxxx.upstash.io
KV_REST_API_TOKEN=your_upstash_token_here

# PostgreSQL — order & customer tracing
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# ── Email (pick one transport) ────────────────────────────────────────────────
# Priority: if RESEND_API_KEY is set → Resend HTTPS. Else if SMTP_PASSWORD → SMTP.

# Resend — https://resend.com/api-keys (verified domain for custom MAIL_FROM)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SMTP — use provider HOSTNAME only (e.g. smtp.gmail.com), never a raw IP (Railway)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
# SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey, SMTP_PASSWORD=<sendgrid_api_key>
# MAIL_FROM=PayOS <you@gmail.com>
# MAIL_TO=lamfan011@gmail.com
